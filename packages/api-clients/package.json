{
  "name": "pagopa-interop-probing-api-clients",
  "version": "1.0.0",
  "private": true,
  "description": "PagoPA Interop Probing Api Clients",
  "main": "dist",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:autofix": "eslint . --fix",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "build": "tsc",
    "check": "tsc --project tsconfig.check.json",
    "generate-model": "tsx ./generate.ts",
    "clean-generated": "pnpm exec rm ./src/generated/*.ts"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@apidevtools/swagger-parser": "10.1.1",
    "@probing/eslint-config": "workspace:*",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "handlebars": "4.7.9",
    "openapi3-ts": "3.1.0",
    "openapi-zod-client": "1.18.3",
    "tsx": "4.19.1"
  },
  "dependencies": {
    "@zodios/core": "10.9.6",
    "axios": "1.15.0",
    "ts-pattern": "5.1.2",
    "zod": "3.23.8"
  }
}
